# ── Firebase Cloud Sync ──────────────────────────────────────────
# FIXED: Variable name must be GOOGLE_APPLICATION_CREDENTIALS
# Path updated to match setup.sh and cloud_db.py expectations
GOOGLE_APPLICATION_CREDENTIALS=database/firebase_credentials.json

# Alternative: Paste JSON directly (for containerized deployments)
# FIXED: Variable name must be FIREBASE_SERVICE_ACCOUNT_JSON
# FIREBASE_SERVICE_ACCOUNT_JSON='{"type": "service_account", "project_id": "...", ...}'

# Note: FIREBASE_PROJECT_ID is not needed; project ID is inside the credentials JSON.

# ── Admin Account ─────────────────────────────────────────────────
# ADDED: Required for default admin creation on first run
# If ADMIN_PASSWORD is not set, a secure random password will be
# generated and displayed in the console on first run.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

USERNAME=admin
PASSWORD=h@ckAttack2026 
