# ══════════════════════════════════════════════════════════════════
# AuraEcho+ Environment Configuration
# ⚠️  NEVER commit this file to Git — it contains secrets!
# ══════════════════════════════════════════════════════════════════

# ── Online AI — Groq (Primary backend, ultra-fast Llama3-70b) ────
# Free tier available at: https://console.groq.com
# Supports: llama3-70b-8192, mixtral-8x7b-32768, gemma-7b-it
GROQ_API_KEY=your_groq_api_key_here

# ── Online AI — OpenAI (Fallback if Groq fails) ──────────────────
# API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ── Firebase Cloud Sync ───────────────────────────────────────────
# Project ID from: Firebase Console → Project Settings → General
FIREBASE_PROJECT_ID=your-firebase-project-id

# Path to service account JSON (download from Firebase Console
# → Project Settings → Service Accounts → Generate New Private Key)
FIREBASE_CREDENTIALS_PATH=data/firebase_credentials.json

# Alternatively, paste the entire JSON as a string (for cloud deploy):
# FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# ── Application Settings ─────────────────────────────────────────
APP_ENV=development          # development | production | test
DEBUG=false                  # true enables verbose logging
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR

# ── Database Paths ────────────────────────────────────────────────
LOCAL_DB_PATH=database/auraecho.db
AUTH_DB_PATH=database/auth.db

# ── Offline AI (Ollama) ───────────────────────────────────────────
# Change if Ollama runs on a different host/port
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3